# Nexis Environment Variables Template
# Copy this to .env and fill in your values.
# For fly.io, use: flyctl secrets set KEY=value

# ─── Required ────────────────────────────────────────────────────────────────

# Web search API key (get free key at https://serper.dev)
SERPER_API_KEY=

# ─── Optional ────────────────────────────────────────────────────────────────

# Neural/semantic search via Exa AI (get at https://exa.ai)
EXA_API_KEY=

# Cilow memory system integration (get at https://cilow.dev)
CILOW_API_URL=
CILOW_API_KEY=

# Server configuration
PORT=3000
RUST_LOG=info

# ─── SOTA (Cloud/Enterprise Only) ───────────────────────────────────────────

# PostgreSQL connection (fly.io auto-sets this when you attach a database)
DATABASE_URL=

# Redis connection (Upstash or self-hosted)
REDIS_URL=

# Stripe billing (for metered billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin API key (for managing the system)
NEXIS_ADMIN_KEY=

# OpenTelemetry collector endpoint
OTLP_ENDPOINT=http://localhost:4317
